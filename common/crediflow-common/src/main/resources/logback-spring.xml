<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <!-- Structured JSON Log Example (Can use net.logstash.logback.encoder.LogstashEncoder in production) -->
            <layout class="ch.qos.logback.classic.PatternLayout">
                <Pattern>{"time":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","trace_id":"%X{trace_id:-N/A}","request_id":"%X{request_id:-N/A}","thread":"%thread","logger":"%logger{40}","message":"%msg"}%n</Pattern>
            </layout>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
